{
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false
  },
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ]
    }
  }
}
